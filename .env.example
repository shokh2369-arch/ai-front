# ─────────────────────────────────────────────────────────────
# start.ai — web frontend configuration
#
# The frontend is a static app (no build step). It reads its API base at
# runtime from config.js → window.START_AI_CONFIG.apiBase.
#
# This .env.example documents the single setting. To apply it, copy the value
# into config.js (that's what the browser actually loads).
# ─────────────────────────────────────────────────────────────

# Base URL of the Go backend.
#   ""                       -> same origin (default; used when the backend
#                               serves this folder, i.e. just open the API port)
#   http://localhost:8080    -> when you run the frontend separately
API_BASE_URL=
